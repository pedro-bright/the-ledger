---
import '../styles/global.css';
// Fraunces — display serif (weight + opsz axes, + italic).
import '@fontsource-variable/fraunces/opsz.css';
import '@fontsource-variable/fraunces/opsz-italic.css';
// Source Serif 4 — body reading serif (weight axis, + italic).
import '@fontsource-variable/source-serif-4/wght.css';
import '@fontsource-variable/source-serif-4/wght-italic.css';
// Inter — UI chrome.
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
// JetBrains Mono — metadata, dates, identifiers.
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';

import SEO from '../components/SEO.astro';
import PostHog from '../components/posthog.astro';
import UtilBar from '../components/chrome/UtilBar.astro';
import Masthead from '../components/chrome/Masthead.astro';
import TopNav from '../components/chrome/TopNav.astro';
import SiteFooter from '../components/chrome/SiteFooter.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  /**
   * Layout variant.
   *  - `article`: default 3-col with optional left/right rails. Used for long-form pages.
   *  - `index`:   3-col with wider rail possibilities; used for list/index pages.
   *  - `full`:    single column, narrow max-width; used for About, 404, Graph.
   */
  layout?: 'article' | 'index' | 'full';
}

const { title, description, image, type, layout = 'index' } = Astro.props;
const pageTitle = !title || title === 'The Ledger'
  ? 'The Ledger — A durable historical record of AI'
  : `${title} — The Ledger`;

// Slot presence drives the grid shape.
const hasLeftRail = Astro.slots.has('leftRail');
const hasRightRail = Astro.slots.has('rightRail');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="The Ledger" href="/feed.xml" />
    <SEO title={pageTitle} description={description} image={image} type={type} />
    <PostHog />
  </head>
  <body class="min-h-screen flex flex-col bg-page-bg text-ink">
    <a href="#main" class="skip-link">Skip to main content</a>
    <UtilBar />
    <Masthead />
    <TopNav />
    <main id="main" tabindex="-1" class="flex-1">
      <div
        class="wiki-layout"
        data-layout={layout}
        data-left-rail={hasLeftRail}
        data-right-rail={hasRightRail}
      >
        {hasLeftRail && layout !== 'full' && (
          <aside class="wiki-rail" data-side="left" aria-label="Navigation sidebar">
            <slot name="leftRail" />
          </aside>
        )}
        <div class="wiki-main">
          <slot />
        </div>
        {hasRightRail && layout !== 'full' && (
          <aside class="wiki-rail" data-side="right" aria-label="Supplementary information">
            <slot name="rightRail" />
          </aside>
        )}
      </div>
    </main>
    <SiteFooter />
  </body>
</html>
