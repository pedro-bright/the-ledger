---
import '../styles/global.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
// Fraunces variable — weight + optical size axes. Loaded once, serves display + reading serif.
import '@fontsource-variable/fraunces/opsz.css';
import SEO from '../components/SEO.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const { title, description, image, type } = Astro.props;
const pageTitle = !title || title === 'The Ledger'
  ? 'The Ledger — A durable historical record of AI'
  : `${title} — The Ledger`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="The Ledger" href="/feed.xml" />
    <SEO title={pageTitle} description={description} image={image} type={type} />
  </head>
  <body class="bg-ledger-bg text-ledger-text font-sans antialiased min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 border-b border-ledger-border bg-ledger-bg/80 backdrop-blur-xl">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="font-display text-xl font-medium tracking-display-tight hover:text-white transition-colors" style="font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;">
            The Ledger
          </a>
          <div class="flex items-center gap-1">
            <a href="/" class="nav-link">Timeline</a>
            <a href="/threads" class="nav-link">Threads</a>
            <a href="/controversies" class="nav-link">Controversies</a>
            <a href="/actors" class="nav-link">Actors</a>
            <a href="/graph" class="nav-link">Graph</a>
            <a href="/explore" class="nav-link">Explore</a>
            <a
              href="https://github.com/pedro-bright/the-ledger/issues/new?template=source-tip.yml"
              target="_blank"
              rel="noopener noreferrer"
              class="nav-link"
            >
              Contribute
            </a>
            <a
              href="/feed.xml"
              class="nav-link ml-1 flex items-center"
              title="RSS Feed"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 11a9 9 0 0 1 9 9" />
                <path d="M4 4a16 16 0 0 1 16 16" />
                <circle cx="5" cy="19" r="1" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-ledger-border mt-auto">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-ledger-text-muted">
          <p class="font-display italic" style="font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;">A durable historical record of AI</p>
          <div class="flex items-center gap-4">
            <a
              href="https://github.com/pedro-bright/the-ledger"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-ledger-text transition-colors"
            >
              GitHub
            </a>
            <span class="text-ledger-text-dim">·</span>
            <a
              href="/feed.xml"
              class="hover:text-ledger-text transition-colors flex items-center gap-1"
            >
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 11a9 9 0 0 1 9 9" />
                <path d="M4 4a16 16 0 0 1 16 16" />
                <circle cx="5" cy="19" r="1" />
              </svg>
              RSS
            </a>
            <span class="text-ledger-text-dim">·</span>
            <span class="font-mono text-xs">CC BY-SA 4.0</span>
          </div>
        </div>
      </div>
    </footer>

    <style is:global>
      .nav-link {
        @apply px-3 py-1.5 text-sm text-ledger-text-muted hover:text-ledger-text rounded-md transition-colors;
      }

      /* Prose styles for rendered markdown — long-form editorial reading. */
      .prose {
        @apply text-ledger-text;
        max-width: 65ch;
        font-size: 1.0625rem; /* 17px — slight bump over base for comfortable long-reads */
        line-height: 1.72;
      }
      .prose h1 {
        font-family: 'Fraunces Variable', 'Iowan Old Style', Georgia, serif;
        font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;
        font-feature-settings: 'kern', 'liga', 'ss01';
        font-weight: 500;
        font-size: 2.25rem;
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: #fff;
        margin: 2rem 0 1rem;
      }
      .prose h2 {
        font-family: 'Fraunces Variable', 'Iowan Old Style', Georgia, serif;
        font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;
        font-feature-settings: 'kern', 'liga', 'ss01';
        font-weight: 500;
        font-size: 1.625rem;
        line-height: 1.15;
        letter-spacing: -0.015em;
        color: #fff;
        margin: 2.25rem 0 0.75rem;
      }
      .prose h3 {
        @apply text-lg font-semibold mt-8 mb-2 text-ledger-text tracking-tight;
      }
      .prose p {
        @apply mb-5;
      }
      .prose ul,
      .prose ol {
        @apply mb-5 pl-6;
      }
      .prose ul {
        @apply list-disc marker:text-ledger-text-dim;
      }
      .prose ol {
        @apply list-decimal marker:text-ledger-text-dim;
      }
      .prose li {
        @apply mb-1.5;
      }
      .prose a {
        @apply text-category-policy border-b border-category-policy/30 hover:border-category-policy transition-colors;
      }
      .prose blockquote {
        font-family: 'Fraunces Variable', 'Iowan Old Style', Georgia, serif;
        font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;
        font-style: italic;
        font-size: 1.125rem;
        line-height: 1.65;
        border-left: 2px solid #2A2A3E;
        padding-left: 1.25rem;
        color: #9B97A0;
        margin: 1.5rem 0;
      }
      .prose code {
        @apply font-mono text-[0.9em] bg-ledger-surface px-1.5 py-0.5 rounded;
      }
      .prose pre {
        @apply bg-ledger-surface p-4 rounded-lg overflow-x-auto mb-5 text-sm;
      }
      .prose pre code {
        @apply bg-transparent px-0 py-0 text-[0.95em];
      }
      .prose strong {
        @apply font-semibold text-white;
      }
      .prose em {
        @apply italic;
      }
      .prose hr {
        @apply border-ledger-border my-10;
      }

      /* Scroll animations — honored only when motion is not reduced. */
      .fade-in-on-scroll {
        opacity: 0;
        transform: translateY(12px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      .fade-in-on-scroll.visible {
        opacity: 1;
        transform: translateY(0);
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        .fade-in-on-scroll {
          opacity: 1;
          transform: none;
          transition: none;
        }
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>

    <script>
      // Scroll-triggered fade-in — skipped entirely when user prefers reduced motion.
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!prefersReducedMotion) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll('.fade-in-on-scroll').forEach((el) => {
          observer.observe(el);
        });
      } else {
        // Immediately reveal everything when motion is reduced.
        document.querySelectorAll('.fade-in-on-scroll').forEach((el) => {
          el.classList.add('visible');
        });
      }
    </script>
  </body>
</html>
