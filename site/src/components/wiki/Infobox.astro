---
// Wikipedia-style infobox: floated-right metadata panel on article pages.
// Consumer provides the <dl>/<ul>/content inside the slot.
interface Props {
  title: string;
  /** Optional wider variant for controversy/actor pages with more content. */
  wide?: boolean;
}

const { title, wide = false } = Astro.props;
---
<aside class={`wiki-infobox${wide ? ' wiki-infobox--wide' : ''}`} aria-labelledby="infobox-title">
  <header class="wiki-infobox__header">
    <h2 id="infobox-title" class="wiki-infobox__title">{title}</h2>
  </header>
  <div class="wiki-infobox__body">
    <slot />
  </div>
</aside>

<style>
  .wiki-infobox {
    float: right;
    width: 280px;
    margin: 4px 0 20px 28px;
    background: var(--color-wiki-surface);
    border: 1px solid var(--color-rule-strong);
    border-radius: 2px;
    font-family: var(--font-sans);
    font-size: 12.5px;
    color: var(--color-ink);
    line-height: 1.45;
  }
  .wiki-infobox--wide { width: 320px; }
  .wiki-infobox__header {
    padding: 8px 12px;
    background: var(--color-wiki-surface-strong);
    border-bottom: 1px solid var(--color-rule-strong);
  }
  .wiki-infobox__title {
    margin: 0;
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 36, 'SOFT' 0, 'WONK' 0;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.2;
  }
  .wiki-infobox__body {
    padding: 10px 12px 12px;
  }
  /* Targeting any dl directly inside (.wiki-infobox dl) — the canonical shape. */
  .wiki-infobox :global(dl) {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 7px 10px;
    margin: 0;
  }
  .wiki-infobox :global(dt) {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ink-muted);
    line-height: 1.4;
    margin: 0;
  }
  .wiki-infobox :global(dd) {
    font-size: 12.5px;
    color: var(--color-ink);
    margin: 0;
    min-width: 0;
  }
  .wiki-infobox :global(dd ul) {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .wiki-infobox :global(dd li) {
    padding: 1px 0;
  }
  .wiki-infobox :global(a) {
    color: var(--color-wiki-link);
  }
  .wiki-infobox :global(a:hover) { text-decoration: underline; }
  .wiki-infobox :global(.mono) {
    font-family: var(--font-mono);
    font-size: 11.5px;
  }

  /* Between 1024–1200px the right rail narrows to 240px and the main column
     tightens; shrink the infobox in step so prose keeps a readable measure. */
  @media (max-width: 1200px) {
    .wiki-infobox { width: 240px; margin: 4px 0 18px 24px; }
    .wiki-infobox--wide { width: 280px; }
  }
  /* At 1024px the right rail drops and the main column widens again — the
     floated infobox is fine, just slightly narrower to leave prose headroom. */
  @media (max-width: 1024px) {
    .wiki-infobox { width: 260px; }
    .wiki-infobox--wide { width: 300px; }
  }
  /* Below the right-rail breakpoint: become a full-width block above prose. */
  @media (max-width: 780px) {
    .wiki-infobox,
    .wiki-infobox--wide {
      float: none;
      width: 100%;
      margin: 0 0 20px 0;
    }
  }
</style>
