---
// Index-page header: eyebrow label + title + optional italic subtitle + rule.
// Pattern reused across Threads/Controversies/Actors/About index pages.
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  /** Drop the bottom rule (for pages that immediately render a filter bar instead). */
  noRule?: boolean;
}

const { eyebrow, title, subtitle, noRule = false } = Astro.props;
---
<header class={`page-header${noRule ? ' page-header--no-rule' : ''}`}>
  {eyebrow && <p class="page-header__eyebrow label-eyebrow">{eyebrow}</p>}
  <h1 class="page-header__title">{title}</h1>
  {subtitle && <p class="page-header__subtitle">{subtitle}</p>}
</header>

<style>
  .page-header {
    padding-bottom: 20px;
    margin-bottom: 28px;
    border-bottom: 1px solid var(--color-rule-strong);
  }
  .page-header--no-rule {
    border-bottom: none;
    margin-bottom: 20px;
  }
  .page-header__eyebrow {
    margin: 0 0 8px;
  }
  .page-header__title {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;
    font-weight: 500;
    font-size: 2.5rem;
    line-height: 1.05;
    letter-spacing: -0.018em;
    color: var(--color-ink-dim);
    margin: 0;
    text-wrap: balance;
  }
  .page-header__subtitle {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;
    font-style: italic;
    font-size: 1.0625rem;
    line-height: 1.5;
    color: var(--color-ink-mid);
    margin: 12px 0 0;
    max-width: 62ch;
  }
  @media (max-width: 600px) {
    .page-header__title { font-size: 2rem; }
    .page-header__subtitle { font-size: 1rem; }
  }
</style>
