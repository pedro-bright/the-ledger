---
import Base from '../../layouts/Base.astro';
import ConfidenceBadge from '../../components/ConfidenceBadge';
import ContestationBadge from '../../components/ContestationBadge';
import SignificanceHistory from '../../components/SignificanceHistory';
import { loadEvents, getCategoryColor, loadThreads, loadActors } from '../../lib/content';

export function getStaticPaths() {
  const events = loadEvents();
  return events.map((event) => ({
    params: { id: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const categoryColor = getCategoryColor(event.category);
const threads = loadThreads();
const actors = loadActors();
const allEvents = loadEvents();
const linkedThreads = threads.filter((t) => event.threads?.includes(t.id));

// Resolve actor names
const actorMap = new Map(actors.map((a) => [a.id, a]));

// Resolve related events to titles
const relatedEvents = (event.related || []).map((relId: string) => {
  const found = allEvents.find((e) => e.id === relId);
  return { id: relId, title: found?.title || relId, slug: found?.slug || relId };
});

const significanceLabel: Record<string, string> = {
  landmark: 'Landmark',
  major: 'Major',
  notable: 'Notable',
};
---

<Base title={event.title} description={`${event.title} — ${new Date(event.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}`}>
  <article class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-12">
      <!-- Main content -->
      <div>
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-xs font-mono text-ledger-text-dim mb-6">
          <a href="/" class="hover:text-ledger-text transition-colors">Timeline</a>
          <span>/</span>
          <a href="/explore" class="hover:text-ledger-text transition-colors">Events</a>
          <span>/</span>
          <span class="text-ledger-text-muted">{event.id}</span>
        </nav>

        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <time class="text-sm font-mono text-ledger-text-dim">
            {new Date(event.date).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <span
            class="px-2.5 py-0.5 text-xs font-medium uppercase tracking-wider rounded-full border"
            style={`background: ${categoryColor}20; color: ${categoryColor}; border-color: ${categoryColor}40;`}
          >
            {event.category.replace('-', ' ')}
          </span>
          {event.significance && (
            <span class="px-2.5 py-0.5 text-xs font-mono font-medium uppercase tracking-wider text-ledger-text-muted bg-ledger-surface rounded-full border border-ledger-border">
              {significanceLabel[event.significance] || event.significance}
            </span>
          )}
        </div>

        <!-- Title -->
        <h1
          class="text-2xl sm:text-3xl font-bold text-white mb-4 border-l-[3px] pl-4"
          style={`border-color: ${categoryColor};`}
        >
          {event.title}
        </h1>

        <!-- Badges -->
        <div class="flex flex-wrap gap-2 mb-6">
          <ConfidenceBadge level={event.confidence} />
          {event.contestation?.status && (
            <ContestationBadge status={event.contestation.status} />
          )}
        </div>

        <!-- Thread links (cross-navigation) -->
        {linkedThreads.length > 0 && (
          <div class="flex flex-wrap items-center gap-2 mb-6">
            <span class="text-xs font-mono text-ledger-text-dim">Part of:</span>
            {linkedThreads.map((thread) => (
              <a
                href={`/threads/${thread.slug}`}
                class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium text-category-policy bg-category-policy/10 rounded-full border border-category-policy/20 hover:bg-category-policy/20 transition-colors"
              >
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-3.03l4.5-4.5a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                </svg>
                {thread.title}
              </a>
            ))}
          </div>
        )}

        <!-- Content -->
        <div class="prose max-w-none" set:html={event.htmlContent} />

        <!-- Significance history -->
        {event.significance_history && event.significance_history.length > 1 && (
          <div class="mt-8 pt-8 border-t border-ledger-border">
            <SignificanceHistory history={event.significance_history} />
          </div>
        )}

        <!-- Tags as styled pills -->
        {event.tags && event.tags.length > 0 && (
          <div class="mt-8 pt-8 border-t border-ledger-border">
            <h3 class="text-xs font-mono uppercase tracking-wider text-ledger-text-dim mb-3">
              Tags
            </h3>
            <div class="flex flex-wrap gap-2">
              {event.tags.map((tag: string) => (
                <span class="px-2.5 py-1 text-xs font-mono text-ledger-text-muted bg-ledger-surface rounded-full border border-ledger-border hover:border-ledger-border-light transition-colors">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="mt-8 lg:mt-0">
        <div class="sticky top-20 space-y-6">
          <!-- Sources -->
          {event.sources && event.sources.length > 0 && (
            <div class="p-4 rounded-lg border border-ledger-border bg-ledger-surface/30">
              <h3 class="text-xs font-mono uppercase tracking-wider text-ledger-text-dim mb-3">
                Sources ({event.sources.length})
              </h3>
              <div class="space-y-3">
                {event.sources.map((source: any) => (
                  <div class="text-sm">
                    <a
                      href={source.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-category-policy hover:underline line-clamp-2"
                    >
                      {source.title || source.url}
                    </a>
                    <div class="flex items-center gap-2 mt-0.5">
                      {source.publisher && (
                        <span class="text-xs text-ledger-text-muted">{source.publisher}</span>
                      )}
                      <span class="text-[10px] font-mono uppercase tracking-wider text-ledger-text-dim px-1.5 py-0.5 bg-ledger-surface rounded border border-ledger-border">
                        {source.type}
                      </span>
                    </div>
                    {source.archive_url && (
                      <a
                        href={source.archive_url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs text-ledger-text-dim hover:text-ledger-text-muted transition-colors"
                      >
                        [archive]
                      </a>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Actors as styled pills -->
          {event.actors && event.actors.length > 0 && (
            <div class="p-4 rounded-lg border border-ledger-border bg-ledger-surface/30">
              <h3 class="text-xs font-mono uppercase tracking-wider text-ledger-text-dim mb-3">
                Actors
              </h3>
              <div class="space-y-2">
                {event.actors.map((actor: any) => {
                  const actorData = actorMap.get(actor.id);
                  const displayName = actorData?.name || actor.id;
                  return (
                    <div class="flex items-center justify-between gap-2">
                      <a
                        href={`/explore?actor=${actor.id}`}
                        class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-mono text-ledger-text bg-ledger-surface rounded-full border border-ledger-border hover:border-ledger-border-light hover:text-white transition-colors"
                      >
                        {displayName}
                      </a>
                      <span class="text-[10px] text-ledger-text-dim capitalize">{actor.role}</span>
                    </div>
                  );
                })}
              </div>
            </div>
          )}

          <!-- Related events as clickable links -->
          {relatedEvents.length > 0 && (
            <div class="p-4 rounded-lg border border-ledger-border bg-ledger-surface/30">
              <h3 class="text-xs font-mono uppercase tracking-wider text-ledger-text-dim mb-3">
                Related Events
              </h3>
              <div class="space-y-1.5">
                {relatedEvents.map((rel) => (
                  <a
                    href={`/events/${rel.slug}`}
                    class="block text-sm text-ledger-text-muted hover:text-category-policy transition-colors py-1"
                  >
                    {rel.title}
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Metadata -->
          <div class="p-4 rounded-lg border border-ledger-border bg-ledger-surface/30">
            <h3 class="text-xs font-mono uppercase tracking-wider text-ledger-text-dim mb-3">
              Metadata
            </h3>
            <dl class="space-y-2 text-sm">
              <div class="flex justify-between">
                <dt class="text-ledger-text-dim">ID</dt>
                <dd class="font-mono text-xs text-ledger-text-muted">{event.id}</dd>
              </div>
              {event.state && (
                <div class="flex justify-between">
                  <dt class="text-ledger-text-dim">State</dt>
                  <dd class="font-mono text-xs capitalize text-ledger-text-muted">{event.state}</dd>
                </div>
              )}
              {event.regions && (
                <div class="flex justify-between">
                  <dt class="text-ledger-text-dim">Regions</dt>
                  <dd class="font-mono text-xs text-ledger-text-muted">{event.regions.join(', ')}</dd>
                </div>
              )}
            </dl>
          </div>
        </div>
      </aside>
    </div>
  </article>
</Base>
