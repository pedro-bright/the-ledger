---
import Base from '../../layouts/Base.astro';
import ArticleShell from '../../components/wiki/ArticleShell.astro';
import Infobox from '../../components/wiki/Infobox.astro';
import RailSection from '../../components/wiki/RailSection.astro';
import CategoryTag from '../../components/wiki/CategoryTag.astro';
import SignificanceFlag from '../../components/wiki/SignificanceFlag.astro';
import ConfidenceBadge from '../../components/ConfidenceBadge';
import ContestationBadge from '../../components/ContestationBadge';
import SignificanceHistory from '../../components/SignificanceHistory';
import { loadEvents, loadThreads, loadActors } from '../../lib/content';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const events = loadEvents();
  return events.map((event) => ({
    params: { id: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const allEvents = loadEvents();
const threads = loadThreads();
const actors = loadActors();
const actorMap = new Map(actors.map((a) => [a.id, a]));
const eventMap = new Map(allEvents.map((e) => [e.id, e]));
const threadMap = new Map(threads.map((t) => [t.id, t]));

// Linked threads for this event.
const linkedThreads = (event.threads || []).map((id: string) => threadMap.get(id)).filter(Boolean);

// Related = union of explicit `related` + events sharing a thread. Dedupe, cap 8.
const relatedIds = new Set<string>(event.related || []);
for (const t of linkedThreads) for (const eId of (t?.events || [])) if (eId !== event.id) relatedIds.add(eId);
const relatedEvents = Array.from(relatedIds)
  .map((id) => eventMap.get(id)).filter(Boolean)
  .sort((a, b) => new Date(b!.date).getTime() - new Date(a!.date).getTime())
  .slice(0, 8) as typeof allEvents;

// Sister events in the same category, capped at 5.
const sisterEvents = allEvents.filter((e) => e.category === event.category && e.id !== event.id).slice(0, 5);

// Best-effort sourcePath — walk the year dir; if anything fails it's left undefined (cosmetic).
let sourcePath: string | undefined;
try {
  const year = new Date(event.date).getUTCFullYear();
  const CONTENT_DIR = path.resolve((import.meta as any).env?.CONTENT_DIR || path.join(process.cwd(), '..', 'content'));
  const match = fs.readdirSync(path.join(CONTENT_DIR, 'events', String(year))).find((f) => f.endsWith(`${event.slug}.md`));
  if (match) sourcePath = `content/events/${year}/${match}`;
} catch {}

const formatCategory = (c: string) => c.replace(/-/g, ' ').replace(/\b\w/g, (s) => s.toUpperCase());
const formatSourceType = (t: string) => t.replace(/_/g, ' ').replace(/-/g, ' ');
const isPrimary = (t?: string) => !!t && /^primary/.test(t);

const breadcrumb = [
  { label: 'Main page', href: '/' },
  { label: 'Timeline', href: '/explore' },
  { label: formatCategory(event.category), href: `/explore?category=${event.category}` },
  { label: event.title },
];

const subtitle = `A ledger entry in the ${formatCategory(event.category).toLowerCase()} archive, dated ${event.date}.`;
const hasSigHistory = event.significance_history && event.significance_history.length > 1;
const description = `${event.title} — ${event.date}`;
---

<Base title={event.title} description={description} layout="article">
  <!-- LEFT RAIL -->
  <Fragment slot="leftRail">
    <RailSection title="Navigate">
      <ul class="rail-list">
        <li><a href="/explore">Back to timeline</a></li>
        <li><a href="/">Main page</a></li>
        <li><a href={`/explore?category=${event.category}`}>{formatCategory(event.category)}</a></li>
        <li><a href="/threads">All threads</a></li>
      </ul>
    </RailSection>

    {linkedThreads.length > 0 && (
      <RailSection title="Related threads">
        <ul class="rail-list">
          {linkedThreads.map((t: any) => (
            <li><a href={`/threads/${t.slug}`}>{t.title}</a></li>
          ))}
        </ul>
      </RailSection>
    )}

    {sisterEvents.length > 0 && (
      <RailSection title={`${formatCategory(event.category)} · sister entries`}>
        <ul class="rail-list rail-list--stacked">
          {sisterEvents.map((e) => (
            <li class="rail-stack">
              <a href={`/events/${e.slug}`}>{e.title}</a>
              <time class="rail-stack__date font-mono" datetime={e.date}>{e.date}</time>
            </li>
          ))}
        </ul>
      </RailSection>
    )}
  </Fragment>

  <!-- RIGHT RAIL -->
  <Fragment slot="rightRail">
    {event.actors && event.actors.length > 0 && (
      <RailSection title="Actors">
        <ul class="rail-list rail-list--stacked">
          {event.actors.map((a: any) => {
            const actor = actorMap.get(a.id);
            return (
              <li class="rail-stack">
                <a href={`/actors/${a.id}`}>{actor?.name || a.id}</a>
                <span class="rail-stack__meta">
                  {actor?.type && <span class="rail-stack__type">{actor.type.replace(/-/g, ' ')}</span>}
                  {a.role && <span class="rail-stack__role">· {a.role}</span>}
                </span>
              </li>
            );
          })}
        </ul>
      </RailSection>
    )}

    <RailSection title="Epistemic key">
      <dl class="epistemic-key">
        <dt class="epistemic-key__term epistemic-key__term--landmark">Landmark</dt>
        <dd>Fundamentally alters the trajectory. Future textbooks will cover it. 2–5 per year.</dd>
        <dt class="epistemic-key__term epistemic-key__term--major">Major</dt>
        <dd>Meaningfully shifts the landscape. 2–4 per month.</dd>
        <dt class="epistemic-key__term epistemic-key__term--notable">Notable</dt>
        <dd>Worth documenting for the record. Significance can be upgraded later.</dd>
        <dt class="epistemic-key__term">Confidence</dt>
        <dd>High = primary sources corroborate. Medium = credible secondary only. Low = provisional. Disputed = credible sources disagree.</dd>
      </dl>
    </RailSection>
  </Fragment>

  <!-- ARTICLE BODY -->
  <ArticleShell
    title={event.title}
    subtitle={subtitle}
    breadcrumb={breadcrumb}
    lastModified={event.date}
    sourcePath={sourcePath}
  >
    <Fragment slot="infobox">
      <Infobox title="Entry metadata">
        <dl>
          <dt>Date</dt>
          <dd><time class="mono" datetime={event.date}>{event.date}</time></dd>
          <dt>Category</dt>
          <dd><a href={`/explore?category=${event.category}`}><CategoryTag category={event.category} /></a></dd>
          {event.significance && <><dt>Significance</dt><dd><SignificanceFlag level={event.significance} /></dd></>}
          {event.confidence && event.confidence !== 'high' && <><dt>Confidence</dt><dd><ConfidenceBadge level={event.confidence} /></dd></>}
          {event.contestation?.status && <><dt>Contestation</dt><dd><ContestationBadge status={event.contestation.status} /></dd></>}
          {event.state && <><dt>State</dt><dd class="mono">{event.state}</dd></>}
          {event.actors && event.actors.length > 0 && (
            <>
              <dt>Actors</dt>
              <dd>
                <ul>
                  {event.actors.map((a: any) => {
                    const actor = actorMap.get(a.id);
                    return (
                      <li>
                        <a href={`/actors/${a.id}`}>{actor?.name || a.id}</a>
                        {a.role && <span class="infobox-role"> — {a.role}</span>}
                      </li>
                    );
                  })}
                </ul>
              </dd>
            </>
          )}
          {event.regions && event.regions.length > 0 && <><dt>Regions</dt><dd>{event.regions.join(', ')}</dd></>}
          {event.tags && event.tags.length > 0 && <><dt>Tags</dt><dd class="mono">{event.tags.join(', ')}</dd></>}
          {linkedThreads.length > 0 && (
            <>
              <dt>Threads</dt>
              <dd><ul>{linkedThreads.map((t: any) => <li><a href={`/threads/${t.slug}`}>{t.title}</a></li>)}</ul></dd>
            </>
          )}
          <dt>ID</dt>
          <dd><span class="mono">{event.id}</span></dd>
        </dl>
      </Infobox>
    </Fragment>

    <!-- Rendered markdown body -->
    <Fragment set:html={event.htmlContent} />

    {hasSigHistory && (
      <section class="wiki-section">
        <h2 class="wiki-article__h2">Significance history</h2>
        <SignificanceHistory history={event.significance_history} />
      </section>
    )}

    <!-- References -->
    {event.sources && event.sources.length > 0 && (
      <Fragment slot="references">
        <ol>
          {event.sources.map((source: any) => (
            <li>
              <a href={source.url} target="_blank" rel="noopener noreferrer">
                {source.title || source.url}
              </a>
              {source.publisher && <span class="ref-meta">, {source.publisher}</span>}
              {source.date && <span class="ref-date font-mono"> ({source.date})</span>}
              {source.type && (
                <span class={`flag-chip ref-type${isPrimary(source.type) ? ' ref-type--primary' : ''}`}>
                  {formatSourceType(source.type)}
                </span>
              )}
              {source.archive_url && (
                <>
                  {' '}
                  <a href={source.archive_url} target="_blank" rel="noopener noreferrer" class="ref-archive">
                    archived copy
                  </a>
                </>
              )}
            </li>
          ))}
        </ol>
      </Fragment>
    )}

    <!-- See also -->
    {relatedEvents.length > 0 && (
      <Fragment slot="seeAlso">
        <ul>
          {relatedEvents.map((e) => (
            <li>
              <a href={`/events/${e.slug}`}>{e.title}</a>
              <time class="see-also__date font-mono" datetime={e.date}> — {e.date}</time>
            </li>
          ))}
        </ul>
      </Fragment>
    )}
  </ArticleShell>
</Base>

<style>
  .wiki-section { margin-top: 2rem; }
  .rail-list--stacked > li { display: block; }
  .rail-stack { padding: 5px 0; line-height: 1.4; }
  .rail-stack__date,
  .rail-stack__meta { display: block; font-size: 11px; color: var(--color-ink-faint); margin-top: 1px; }
  .rail-stack__type { text-transform: capitalize; }
  .rail-stack__role { margin-left: 3px; }
  .infobox-role { color: var(--color-ink-faint); font-size: 11px; }

  .epistemic-key { display: grid; grid-template-columns: 1fr; gap: 2px 0; margin: 0; }
  .epistemic-key dt {
    margin-top: 6px; font-family: var(--font-sans); font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-ink-muted);
  }
  .epistemic-key dt:first-child { margin-top: 0; }
  .epistemic-key__term--landmark { color: #7A5A00; }
  .epistemic-key__term--major { color: #0A4D82; }
  .epistemic-key__term--notable { color: #5C564D; }
  .epistemic-key dd { margin: 2px 0 0; font-size: 12.5px; color: var(--color-ink-mid); line-height: 1.45; }

  .ref-meta { color: var(--color-ink-mid); }
  .ref-date { font-size: 12px; color: var(--color-ink-faint); }
  .ref-type { margin-left: 6px; text-transform: lowercase; }
  .ref-type--primary { background: #DBECF9; color: #0A4D82; }
  .ref-archive {
    font-family: var(--font-sans); font-size: 11.5px; color: var(--color-ink-faint);
    text-decoration: underline dotted;
  }
  .ref-archive:hover { color: var(--color-wiki-link); }
  .see-also__date { color: var(--color-ink-faint); font-size: 12px; font-style: normal; }
</style>
