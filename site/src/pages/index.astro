---
import Base from '../layouts/Base.astro';
import FeaturedBox from '../components/wiki/FeaturedBox.astro';
import EventRow from '../components/wiki/EventRow.astro';
import RailSection from '../components/wiki/RailSection.astro';
import CategoryTag from '../components/wiki/CategoryTag.astro';
import SignificanceFlag from '../components/wiki/SignificanceFlag.astro';
import {
  loadEvents,
  loadThreads,
  loadControversies,
  loadActors,
  getCategories,
  getExcerpt,
  buildThreadEventMap,
} from '../lib/content';

const events = loadEvents();
const threads = loadThreads();
const controversies = loadControversies();
const actors = loadActors();
const categories = getCategories();
const threadEventMap = buildThreadEventMap(events);

// ─── Dates ────────────────────────────────────────────────────
// Build the "today" label and ISO from local-time fields so the visible label
// and the <time datetime> attribute can never disagree across UTC offsets.
const today = new Date();
const todayIso = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
const todayMonthDay = todayIso.slice(5, 10); // MM-DD
const todayLabel = today.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

// ─── Today's featured entry ───────────────────────────────────
// Rotate daily through landmarks (and fall back to majors, then to any
// event) so the front page actually changes day-to-day. The index is a
// deterministic function of today's calendar date — same entry for every
// reader on the same UTC day, then advances at midnight UTC.
const landmarkEvents = events.filter((e) => e.significance === 'landmark');
const majorEvents = events.filter((e) => e.significance === 'major');
const featuredPool =
  landmarkEvents.length > 0 ? landmarkEvents :
  majorEvents.length > 0 ? majorEvents :
  events;
const daysSinceEpoch = Math.floor(
  Date.UTC(today.getFullYear(), today.getMonth(), today.getDate()) / 86_400_000,
);
const featured = featuredPool.length > 0
  ? featuredPool[daysSinceEpoch % featuredPool.length]
  : undefined;
const featuredExcerpt = featured ? getExcerpt(featured.content, 320) : '';
// Parse ISO date as a local-date (not UTC midnight) so the visible label
// can't drift off-by-one in negative-offset timezones.
function formatLocalIsoDate(iso: string, options: Intl.DateTimeFormatOptions): string {
  const m = /^(\d{4})-(\d{2})-(\d{2})/.exec(iso);
  if (!m) return iso;
  const [, y, mo, d] = m;
  return new Date(Number(y), Number(mo) - 1, Number(d)).toLocaleDateString('en-US', options);
}
const featuredDateLabel = featured
  ? formatLocalIsoDate(featured.date, { month: 'short', day: 'numeric', year: 'numeric' })
  : '';

// ─── On this day (historical matches, excluding current year) ─
const onThisDay = events
  .filter((e) => {
    const md = e.date.slice(5, 10);
    const year = e.date.slice(0, 4);
    return md === todayMonthDay && year !== todayIso.slice(0, 4);
  })
  .slice(0, 5);

// ─── Recent entries ───────────────────────────────────────────
const recentEvents = events.slice(0, 10);

// ─── Ongoing threads ──────────────────────────────────────────
const threadSummaries = threads.map((t) => {
  const list = threadEventMap.get(t.id) || [];
  return {
    ...t,
    eventCount: t.events?.length || list.length,
  };
});
const activeThreads = threadSummaries
  .filter((t) => t.status === 'active')
  .sort((a, b) => b.eventCount - a.eventCount);
const ongoingThreads = activeThreads.slice(0, 4);

// ─── Right-rail picks ─────────────────────────────────────────
const featuredThread = activeThreads.find((t) => t.curator) || activeThreads[0];
const activeControversies = controversies
  .filter((c) => c.status === 'active')
  .slice(0, 3);

// ─── Category counts for left rail ────────────────────────────
const categoryCounts = new Map<string, number>();
for (const e of events) {
  categoryCounts.set(e.category, (categoryCounts.get(e.category) || 0) + 1);
}

// ─── Random entry (picked at build time) ──────────────────────
const randomEvent = events[Math.floor(Math.random() * events.length)];

// ─── Stats line ───────────────────────────────────────────────
const stats = {
  entries: events.length,
  threads: threads.length,
  controversies: controversies.length,
  actors: actors.length,
};
---

<Base layout="index" description="An open-source, sourced chronicle of AI history — events, threads, controversies, and the revisions that reinterpret them. Curated by Terry Tang.">
  <!-- 1. Intro block -->
  <section class="intro">
    <p class="label-eyebrow">§ The Ledger</p>
    <h1 class="intro__title font-display">A durable historical record of AI.</h1>
    <p class="intro__lede">
      An open-source ledger of AI history: events, threads, controversies, and the revisions that reinterpret them. Every claim is sourced and contestable.
    </p>
    <p class="intro__curator">
      <span class="intro__curator-label">Curator's note.</span>
      This ledger treats AI as history in the making, not a running news cycle. Every entry is sourced, dated, and contestable; where the record changes, the history stays visible. <span class="intro__curator-sig">— Terry Tang</span>
    </p>
    <p class="intro__stats font-mono">
      <span>{stats.entries} entries</span>
      <span class="sep">·</span>
      <span>{stats.threads} threads</span>
      <span class="sep">·</span>
      <span>{stats.controversies} controversies</span>
      <span class="sep">·</span>
      <span>{stats.actors} actors</span>
      <span class="sep">·</span>
      <span>updated <time datetime={todayIso}>{todayLabel}</time></span>
    </p>
  </section>

  <!-- 2. Today's featured entry -->
  {featured && (
    <FeaturedBox title="Today's featured entry" date={featuredDateLabel} dateIso={featured.date} meta="§ Editor's pick">
      <h3><a href={`/events/${featured.slug}`}>{featured.title}</a></h3>
      <p>{featuredExcerpt}</p>
      <p class="featured-meta">
        <CategoryTag category={featured.category} />
        {featured.significance && <SignificanceFlag level={featured.significance} />}
        <time class="featured-date font-mono" datetime={featured.date}>{featured.date}</time>
      </p>
      <a class="read-more" href={`/events/${featured.slug}`}>Continue reading →</a>
    </FeaturedBox>
  )}

  <!-- 3. On this day -->
  {onThisDay.length > 0 && (
    <section class="home-section home-section--compact">
      <h2 class="home-section__title font-display">On this day</h2>
      <ul class="wiki-list-dated">
        {onThisDay.map((e) => (
          <li>
            <span class="date"><time datetime={e.date}>{e.date.slice(0, 4)}</time></span>
            <a href={`/events/${e.slug}`}>{e.title}</a>
            <CategoryTag category={e.category} />
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- 4. Recent entries -->
  <section class="home-section">
    <h2 class="home-section__title font-display">Recent entries</h2>
    <ul class="home-event-list">
      {recentEvents.map((e) => (
        <EventRow event={e} />
      ))}
    </ul>
    <a href="/explore" class="more-link">All entries →</a>
  </section>

  <!-- 5. Ongoing threads -->
  {ongoingThreads.length > 0 && (
    <section class="home-section">
      <h2 class="home-section__title font-display">Ongoing threads</h2>
      <dl class="wiki-thread-list">
        {ongoingThreads.map((t) => (
          <>
            <dt>
              <a href={`/threads/${t.slug}`} class="wiki-thread-list__title font-display">{t.title}</a>
            </dt>
            <dd>
              {t.core_question && (
                <span class="wiki-thread-list__q">{t.core_question}</span>
              )}
              <span class="wiki-thread-list__meta font-mono">
                {t.eventCount} entries
                {t.curator && <> · curator {t.curator}</>}
              </span>
            </dd>
          </>
        ))}
      </dl>
      <a href="/threads" class="more-link">All threads →</a>
    </section>
  )}

  <hr class="wiki-hr" />

  <!-- 7. Contribute -->
  <section class="home-section home-section--quiet home-contribute">
    <h2 class="home-section__title font-display">Contribute</h2>
    <p>
      The Ledger is open source and improves through careful contribution. Submit a source tip, challenge a claim, or propose a thread — the constitution is in the repo.
    </p>
    <ul class="contribute-links">
      <li>
        <a
          href="https://github.com/pedro-bright/the-ledger/issues/new?template=source-tip.yml"
          target="_blank"
          rel="noopener noreferrer"
        >Submit a source tip</a>
      </li>
      <li><a href="/about#contribute">Contribution guide</a></li>
      <li><a href="/about#editorial">Editorial constitution</a></li>
      <li><a href="/about#evidence">Evidence standards</a></li>
    </ul>
  </section>

  <!-- ─── Left rail ─── -->
  <Fragment slot="leftRail">
    <RailSection title="Navigate">
      <ul class="rail-list rail-list--plain">
        <li><a href="/">Main page</a></li>
        <li><a href="/explore">Timeline</a></li>
        <li><a href="/threads">Threads</a></li>
        <li><a href="/controversies">Controversies</a></li>
        <li><a href="/actors">Actors</a></li>
        <li><a href="/graph">Graph</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </RailSection>

    <RailSection title="Categories">
      <ul class="rail-list">
        {categories.map((c) => (
          <li>
            <a href={`/explore?category=${c.id}`}>
              <CategoryTag category={c.id} variant="pip" class="rail-pip" />
              {c.label}
            </a>
            <span class="count">{categoryCounts.get(c.id) || 0}</span>
          </li>
        ))}
      </ul>
    </RailSection>

    <RailSection title="Tools">
      <ul class="rail-list rail-list--plain">
        <li><a href="/feed.xml">RSS feed</a></li>
        <li>
          <a href="https://github.com/pedro-bright/the-ledger" target="_blank" rel="noopener noreferrer">GitHub</a>
        </li>
        {randomEvent && (
          <li><a href={`/events/${randomEvent.slug}`}>Random entry</a></li>
        )}
      </ul>
    </RailSection>
  </Fragment>

  <!-- ─── Right rail ─── -->
  <Fragment slot="rightRail">
    {featuredThread && (
      <RailSection title="Featured thread">
        <p class="rail-thread">
          <a href={`/threads/${featuredThread.slug}`} class="rail-thread__title font-display">{featuredThread.title}</a>
        </p>
        {featuredThread.core_question && (
          <p class="rail-thread__q">{featuredThread.core_question}</p>
        )}
        <p class="rail-thread__meta font-mono">
          {featuredThread.eventCount} entries
          {featuredThread.curator && <> · curator {featuredThread.curator}</>}
        </p>
      </RailSection>
    )}

    {activeControversies.length > 0 && (
      <RailSection title="Active controversies">
        <ul class="rail-list rail-list--stacked">
          {activeControversies.map((c) => (
            <li>
              <a href={`/controversies/${c.slug}`}>{c.title}</a>
              <span class="rail-controversy__meta font-mono">
                {c.polarity && <>{c.polarity.replace('-', ' ')} · </>}
                {(c.positions?.length || 0)} positions
              </span>
            </li>
          ))}
        </ul>
      </RailSection>
    )}

    <RailSection title="Epistemic key">
      <dl class="epistemic-key">
        <dt><SignificanceFlag level="landmark" /></dt>
        <dd>Fundamentally alters the trajectory; 2–5 per year.</dd>
        <dt><SignificanceFlag level="major" /></dt>
        <dd>Consequential shift in capability, policy, or consensus.</dd>
        <dt><SignificanceFlag level="notable" /></dt>
        <dd>Worth recording; contextual or precedent-setting.</dd>
      </dl>
    </RailSection>
  </Fragment>
</Base>

<style>
  /* 1. Intro */
  .intro {
    padding-bottom: 20px;
    margin-bottom: 28px;
    border-bottom: 1px solid var(--color-rule-strong);
  }
  .intro__title {
    font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;
    font-size: 2.5rem;
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.018em;
    color: var(--color-ink-dim);
    margin: 8px 0 14px;
    text-wrap: balance;
  }
  .intro__lede {
    font-family: var(--font-display);
    /* Fraunces body-italic: opsz 14 softens curves at reading size. */
    font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;
    font-style: italic;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--color-ink-mid);
    max-width: 62ch;
    margin: 0 0 16px;
  }
  .intro__curator {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-ink-mid);
    /* Source Serif 4's '0' is wider than Fraunces italic's, so 62ch in
       this block resolves to a visibly shorter pixel width than the lede's
       62ch above and reads as if line breaks were premature. 86ch here
       targets the same rendered line length as the lede (62ch in Fraunces
       italic ≈ 86ch in Source Serif 4 at this font-size). */
    max-width: 86ch;
    margin: 4px 0 20px;
    padding: 8px 0 10px 16px;
    border-left: 2px solid var(--color-rule-double);
  }
  .intro__curator-label {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;
    font-style: italic;
    font-weight: 500;
    color: var(--color-ink);
    margin-right: 4px;
  }
  .intro__curator-sig {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-ink-muted);
    white-space: nowrap;
  }
  .intro__stats {
    font-size: 0.75rem;
    color: var(--color-ink-faint);
    letter-spacing: 0.04em;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .intro__stats .sep { color: var(--color-rule-strong); }
  @media (max-width: 600px) {
    .intro__title { font-size: 2rem; }
    .intro__lede { font-size: 1rem; }
  }

  /* Section scaffold — default / compact / quiet tiers for rhythm. */
  .home-section {
    margin: 0 0 36px;
  }
  .home-section--compact {
    margin-bottom: 28px;
  }
  .home-section--quiet {
    margin-bottom: 20px;
  }
  .home-section__title {
    font-variation-settings: 'opsz' 36, 'SOFT' 0, 'WONK' 0;
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-ink-dim);
    margin: 0 0 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--color-rule);
  }
  .home-section--compact .home-section__title {
    font-size: 1.25rem;
    margin-bottom: 10px;
  }
  .home-section--quiet .home-section__title {
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-ink-mid);
    border-bottom-color: var(--color-rule);
    margin-bottom: 8px;
  }

  /* Featured box body extras */
  .featured-meta {
    display: inline-flex;
    align-items: baseline;
    gap: 14px;
    margin-top: 4px;
  }
  .featured-date {
    font-size: 11px;
    color: var(--color-ink-faint);
  }

  /* Recent entries list */
  .home-event-list {
    list-style: none;
    padding: 0;
    margin: 0 0 10px;
  }

  /* "More" link — Inter 13px wiki-blue, restrained */
  .more-link {
    display: inline-block;
    margin-top: 10px;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-wiki-link);
  }
  .more-link:hover { text-decoration: underline; }

  /* Ongoing threads dl */
  .wiki-thread-list {
    margin: 0;
  }
  .wiki-thread-list dt {
    margin: 10px 0 3px;
  }
  .wiki-thread-list dt:first-child { margin-top: 0; }
  .wiki-thread-list__title {
    font-variation-settings: 'opsz' 36, 'SOFT' 0, 'WONK' 0;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-wiki-link);
    line-height: 1.25;
  }
  .wiki-thread-list__title:hover { text-decoration: underline; }
  .wiki-thread-list dd {
    margin: 0 0 14px;
    padding-left: 0;
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-mid);
  }
  .wiki-thread-list__q {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;
    font-style: italic;
    color: var(--color-ink-mid);
  }
  .wiki-thread-list__meta {
    display: inline;
    margin-left: 8px;
    font-size: 11.5px;
    color: var(--color-ink-faint);
    letter-spacing: 0.02em;
  }

  /* Contribute */
  .home-contribute p {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink);
    max-width: 62ch;
    margin: 0 0 10px;
  }
  .contribute-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 18px;
    font-family: var(--font-sans);
    font-size: 13px;
  }
  .contribute-links a { color: var(--color-wiki-link); }
  .contribute-links a:hover { text-decoration: underline; }

  /* Rails: plain (no counts) vs stacked (title + meta on separate line) */
  :global(.rail-list--plain > li) {
    justify-content: flex-start;
  }
  :global(.rail-list--stacked > li) {
    display: block;
    padding: 5px 0;
  }
  :global(.rail-controversy__meta) {
    display: block;
    margin-top: 2px;
    font-size: 11px;
    color: var(--color-ink-faint);
    letter-spacing: 0.02em;
    text-transform: lowercase;
  }
  :global(.rail-pip) {
    margin-right: 6px;
  }

  /* Featured thread rail block */
  :global(.rail-thread) { margin: 0 0 4px; }
  :global(.rail-thread__title) {
    font-variation-settings: 'opsz' 36, 'SOFT' 0, 'WONK' 0;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-wiki-link);
    line-height: 1.25;
  }
  :global(.rail-thread__title:hover) { text-decoration: underline; }
  :global(.rail-thread__q) {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;
    font-style: italic;
    font-size: 13px;
    line-height: 1.45;
    color: var(--color-ink-mid);
    margin: 0 0 6px;
  }
  :global(.rail-thread__meta) {
    font-size: 11px;
    color: var(--color-ink-faint);
    letter-spacing: 0.02em;
    margin: 0;
  }

  /* Epistemic key dl */
  :global(.epistemic-key) {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 10px;
    row-gap: 8px;
    margin: 0;
  }
  :global(.epistemic-key dt) {
    margin: 0;
    align-self: start;
    padding-top: 2px;
  }
  :global(.epistemic-key dd) {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 12.5px;
    line-height: 1.45;
    color: var(--color-ink-mid);
  }
</style>
