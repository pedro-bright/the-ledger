---
import Base from '../layouts/Base.astro';
import Graph from '../components/Graph';
import fs from 'node:fs';
import { fileURLToPath } from 'node:url';

// Resolve graph.json relative to this file so the path is stable regardless of cwd.
const graphPath = fileURLToPath(new URL('../../../graph.json', import.meta.url));
const graph = JSON.parse(fs.readFileSync(graphPath, 'utf-8'));
---

<Base title="Graph" description="Relationship graph: events, threads, controversies, and actors connected.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <p class="label-eyebrow mb-3">§ Graph</p>
      <h1 class="font-display text-display-sm font-normal text-white mb-4 leading-[1.05]" style="font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;">
        How everything connects
      </h1>
      <p class="font-display italic text-lg text-ledger-text-muted max-w-[62ch] leading-relaxed" style="font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;">
        {graph.nodes.length} nodes, {graph.edges.length} edges. Events belong to threads; threads contain controversies; events involve actors.
      </p>
    </div>

    <Graph data={graph} client:only="react" />
  </section>
</Base>
