---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/wiki/PageHeader.astro';
import Graph from '../components/Graph';
import fs from 'node:fs';
import { fileURLToPath } from 'node:url';

// Resolve graph.json relative to this file so the path is stable regardless of cwd.
const graphPath = fileURLToPath(new URL('../../../graph.json', import.meta.url));
const graph = JSON.parse(fs.readFileSync(graphPath, 'utf-8'));

const nodeCount = graph.nodes.length;
const edgeCount = graph.edges.length;

const legend = [
  { type: 'event', label: 'Events', color: '#0645AD' },
  { type: 'thread', label: 'Threads', color: '#B45309' },
  { type: 'controversy', label: 'Controversies', color: '#B91C1C' },
  { type: 'actor', label: 'Actors', color: '#047857' },
];
---

<Base
  layout="index"
  title="Graph"
  description="Relationship graph: events, threads, controversies, and actors connected."
>
  <PageHeader
    eyebrow="§ Graph"
    title="How everything connects"
    subtitle={`${nodeCount} nodes, ${edgeCount} edges. Events belong to threads, threads contain controversies, events reference actors. Toggle node types with the controls to isolate a subnetwork.`}
    noRule
  />

  <div class="graph-legend" aria-label="Node-type legend">
    <p class="label-eyebrow">Legend</p>
    <ul class="graph-legend__list">
      {legend.map((l) => (
        <li class="graph-legend__item">
          <span
            class="graph-legend__swatch"
            style={`background:${l.color}`}
            aria-hidden="true"
          ></span>
          <span class="graph-legend__label">{l.label}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="graph-wrap">
    <Graph data={graph} client:only="react" />
  </div>
</Base>

<style>
  .graph-legend {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px 18px;
    margin: 0 0 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-rule);
  }
  .graph-legend__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 18px;
  }
  .graph-legend__item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-ink-mid);
  }
  .graph-legend__swatch {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .graph-legend__label {
    letter-spacing: 0.02em;
  }

  .graph-wrap {
    margin-top: 8px;
  }
</style>
