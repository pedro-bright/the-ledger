---
import Base from '../../layouts/Base.astro';
import ArticleShell from '../../components/wiki/ArticleShell.astro';
import Infobox from '../../components/wiki/Infobox.astro';
import RailSection from '../../components/wiki/RailSection.astro';
import ConfidenceBadge from '../../components/ConfidenceBadge';
import { loadControversies, loadThreads, loadActors, getExcerpt } from '../../lib/content';

export function getStaticPaths() {
  const controversies = loadControversies();
  return controversies.map((controversy) => ({
    params: { id: controversy.slug },
    props: { controversy },
  }));
}

const { controversy } = Astro.props;
const threads = loadThreads();
const actors = loadActors();
const actorMap = new Map(actors.map((a) => [a.id, a]));

const linkedThread = controversy.thread ? threads.find((t) => t.id === controversy.thread) : null;

const allControversies = loadControversies();
const siblings = linkedThread
  ? allControversies.filter((c) => c.thread === linkedThread.id && c.id !== controversy.id)
  : [];

const positions = controversy.positions || [];

// Union + dedupe of sources across positions
const dedupedSources: Array<{ url: string; title: string; publisher?: string }> = [];
const seenUrls = new Set<string>();
for (const p of positions) {
  for (const s of p.sources || []) {
    if (!s?.url || seenUrls.has(s.url)) continue;
    seenUrls.add(s.url);
    dedupedSources.push({ url: s.url, title: s.title || s.url, publisher: s.publisher });
  }
}

const polarityLabel = controversy.polarity
  ? controversy.polarity === 'multi-axis'
    ? 'multi-axis'
    : controversy.polarity
  : 'contested';

const subtitle = linkedThread
  ? `A ${polarityLabel} controversy in the ${linkedThread.title} thread.`
  : `A ${polarityLabel} controversy.`;

const positionLetter = (i: number) => String.fromCharCode(65 + i); // A, B, C…

function preview(claim?: string, n = 120): string {
  if (!claim) return '';
  return claim.length > n ? getExcerpt(claim, n) : claim;
}

function displayActor(id: string): { name: string; href: string } {
  const a = actorMap.get(id);
  return { name: a?.name || id, href: `/actors/${id}` };
}
---

<Base
  layout="article"
  title={controversy.title}
  description={positions[0]?.claim || `Controversy: ${controversy.title}`}
>
  <ArticleShell
    title={controversy.title}
    subtitle={subtitle}
    breadcrumb={[
      { label: 'Main page', href: '/' },
      { label: 'Controversies', href: '/controversies' },
      { label: controversy.title },
    ]}
    lastModified={controversy.last_updated}
    sourcePath={`content/controversies/${controversy.slug}.md`}
  >
    <Fragment slot="infobox">
      <Infobox title="Controversy metadata" wide>
        <dl>
          {controversy.status && (
            <>
              <dt>Status</dt>
              <dd>{controversy.status}</dd>
            </>
          )}
          {controversy.polarity && (
            <>
              <dt>Polarity</dt>
              <dd>{controversy.polarity}</dd>
            </>
          )}
          <dt>Positions</dt>
          <dd><span class="mono">{positions.length}</span></dd>
          {linkedThread && (
            <>
              <dt>Thread</dt>
              <dd><a href={`/threads/${linkedThread.slug}`}>{linkedThread.title}</a></dd>
            </>
          )}
          {controversy.last_updated && (
            <>
              <dt>Last argued</dt>
              <dd><time class="mono" datetime={controversy.last_updated}>{controversy.last_updated}</time></dd>
            </>
          )}
          <dt>ID</dt>
          <dd><span class="mono">{controversy.id}</span></dd>
        </dl>
      </Infobox>
    </Fragment>

    {controversy.content.trim() && (
      <div set:html={controversy.htmlContent} />
    )}

    {positions.length > 0 && positions.map((position, i) => (
      <Fragment>
        {i > 0 && <hr class="wiki-hr" />}
        <section class="position" id={`position-${positionLetter(i).toLowerCase()}`}>
          <h2>
            <span class="position__label">Position {positionLetter(i)}:</span>{' '}
            <em class="position__claim">{position.claim}</em>
          </h2>

          {position.confidence && (
            <p class="position__badge">
              <ConfidenceBadge level={position.confidence as any} />
            </p>
          )}

          {position.proponents && position.proponents.length > 0 && (
            <p class="position__proponents">
              <span class="position__meta-label">Proponents:</span>{' '}
              {position.proponents.map((id: string, j: number) => {
                const { name, href } = displayActor(id);
                return (
                  <Fragment>
                    {j > 0 && <span class="position__sep" aria-hidden="true">, </span>}
                    <a class="position__proponent" href={href}>{name}</a>
                  </Fragment>
                );
              })}
            </p>
          )}

          {position.sources && position.sources.length > 0 && (
            <>
              <h3>Sources</h3>
              <ol class="position__sources">
                {position.sources.map((s: any) => (
                  <li>
                    <a href={s.url} target="_blank" rel="noopener noreferrer">{s.title || s.url}</a>
                    {s.publisher && <span class="position__pub"> — {s.publisher}</span>}
                  </li>
                ))}
              </ol>
            </>
          )}
        </section>
      </Fragment>
    ))}

    {dedupedSources.length > 0 && (
      <Fragment slot="references">
        <ol>
          {dedupedSources.map((s) => (
            <li>
              <a href={s.url} target="_blank" rel="noopener noreferrer">{s.title}</a>
              {s.publisher && <> — {s.publisher}</>}
            </li>
          ))}
        </ol>
      </Fragment>
    )}

    {siblings.length > 0 && (
      <Fragment slot="seeAlso">
        <ul>
          {siblings.map((s) => (
            <li><a href={`/controversies/${s.slug}`}>{s.title}</a></li>
          ))}
          {linkedThread && (
            <li><a href={`/threads/${linkedThread.slug}`}>{linkedThread.title} (thread)</a></li>
          )}
        </ul>
      </Fragment>
    )}
  </ArticleShell>

  <Fragment slot="leftRail">
    <RailSection title="Navigate">
      <ul class="rail-list rail-list--plain">
        <li><a href="/">Main page</a></li>
        <li><a href="/controversies">All controversies</a></li>
        <li><a href="/threads">Threads</a></li>
        <li><a href="/actors">Actors</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </RailSection>

    {linkedThread && (
      <RailSection title="Thread">
        <p class="rail-thread">
          <a href={`/threads/${linkedThread.slug}`} class="rail-thread__title font-display">{linkedThread.title}</a>
        </p>
        {linkedThread.core_question && (
          <p class="rail-thread__q">{linkedThread.core_question}</p>
        )}
      </RailSection>
    )}

    {siblings.length > 0 && (
      <RailSection title="Also in this thread">
        <ul class="rail-list rail-list--plain">
          {siblings.map((s) => (
            <li><a href={`/controversies/${s.slug}`}>{s.title}</a></li>
          ))}
        </ul>
      </RailSection>
    )}
  </Fragment>

  <Fragment slot="rightRail">
    {positions.length > 0 && (
      <RailSection title="Positions at a glance">
        <ol class="rail-positions">
          {positions.map((p, i) => (
            <li>
              <a href={`#position-${positionLetter(i).toLowerCase()}`}>
                <span class="rail-positions__label">Position {positionLetter(i)}</span>
                <span class="rail-positions__claim">{preview(p.claim, 100)}</span>
              </a>
            </li>
          ))}
        </ol>
      </RailSection>
    )}
  </Fragment>
</Base>

<style>
  .position { scroll-margin-top: 20px; }
  .position__label {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 36, 'SOFT' 0, 'WONK' 0;
    font-style: normal; color: var(--color-ink-dim);
  }
  .position__claim { font-family: var(--font-serif); font-style: italic; color: var(--color-ink); font-weight: 500; }
  .position__badge { margin: 6px 0 0; }
  .position__proponents { margin: 10px 0 0; font-size: 0.9375rem; }
  .position__meta-label {
    font-family: var(--font-sans); font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--color-ink-muted); margin-right: 2px;
  }
  .position__proponent { font-family: var(--font-mono); font-size: 12.5px; color: var(--color-wiki-link); }
  .position__proponent:hover { text-decoration: underline; }
  .position__sep { color: var(--color-ink-faint); font-family: var(--font-mono); font-size: 12.5px; }
  .position__sources { padding-left: 1.5rem; margin: 0.5rem 0 1rem; }
  .position__sources li { margin-bottom: 4px; font-family: var(--font-serif); font-size: 0.9375rem; line-height: 1.55; }
  .position__sources a {
    color: var(--color-wiki-link); text-decoration: underline;
    text-decoration-color: rgba(6, 69, 173, 0.35);
  }
  .position__sources a:hover { text-decoration-color: var(--color-wiki-link); }
  .position__pub { color: var(--color-ink-mid); font-size: 0.875rem; }

  :global(.rail-positions) { list-style: none; padding: 0; margin: 0; }
  :global(.rail-positions > li) { padding: 6px 0; border-bottom: 1px dotted var(--color-rule); }
  :global(.rail-positions > li:last-child) { border-bottom: none; }
  :global(.rail-positions a) { display: block; color: var(--color-ink-mid); }
  :global(.rail-positions a:hover) { color: var(--color-wiki-link); }
  :global(.rail-positions__label) {
    display: block; font-family: var(--font-sans); font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-ink-muted); margin-bottom: 2px;
  }
  :global(.rail-positions__claim) {
    display: block; font-family: var(--font-display);
    font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;
    font-style: italic; font-size: 12.5px; line-height: 1.4; color: var(--color-ink-mid);
  }
</style>
