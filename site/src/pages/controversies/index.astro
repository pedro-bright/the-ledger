---
import Base from '../../layouts/Base.astro';
import { loadControversies, loadThreads } from '../../lib/content';

const controversies = loadControversies();
const threads = loadThreads();
const threadMap = new Map(threads.map((t) => [t.id, t]));
---

<Base title="Controversies" description="Active debates and contested positions in AI history.">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-14">
      <p class="label-eyebrow mb-3">§ Active Debates</p>
      <h1 class="font-display text-display-sm font-normal text-white mb-4 leading-[1.05]" style="font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;">Controversies</h1>
      <p class="font-display italic text-lg text-ledger-text-muted max-w-[58ch] leading-relaxed" style="font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;">
        Not everything in AI has consensus. These document multiple positions, their proponents, and the evidence behind each claim.
      </p>
    </div>

    {controversies.length === 0 ? (
      <div class="text-center py-20">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-ledger-surface border border-ledger-border mb-6">
          <svg class="w-7 h-7 text-ledger-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={1.5}>
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
          </svg>
        </div>
        <h3 class="font-display text-2xl font-normal text-ledger-text mb-2" style="font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;">No controversies yet</h3>
        <p class="text-sm text-ledger-text-muted max-w-md mx-auto">
          Controversies are loaded from markdown files in the <code class="font-mono text-xs bg-ledger-surface px-1.5 py-0.5 rounded">content/controversies/</code> directory.
        </p>
      </div>
    ) : (
      <div class="space-y-6">
        {controversies.map((controversy) => {
          const linkedThread = controversy.thread ? threadMap.get(controversy.thread) : null;
          const positions = controversy.positions || [];
          const previewA = positions[0];
          const previewB = positions[1];
          const rest = Math.max(0, positions.length - 2);
          return (
            <a
              href={`/controversies/${controversy.slug}`}
              class="group block rounded-md border border-ledger-border bg-ledger-surface/30 hover:bg-ledger-surface/50 hover:border-ledger-border-light transition-all"
            >
              <!-- Header strip -->
              <header class="px-6 pt-6 pb-4 border-b border-ledger-border/60">
                <div class="flex items-start gap-3 mb-2">
                  <h2 class="font-display text-2xl sm:text-3xl font-medium leading-tight text-ledger-text group-hover:text-white transition-colors flex-1" style="font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;">
                    {controversy.title}
                  </h2>
                  {controversy.status && (
                    <span class={`flex-shrink-0 mt-2 px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider rounded-sm border ${
                      controversy.status === 'active'
                        ? 'text-amber-400 bg-amber-400/10 border-amber-400/20'
                        : controversy.status === 'resolved'
                          ? 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20'
                          : 'text-ledger-text-dim bg-ledger-surface border-ledger-border'
                    }`}>
                      {controversy.status}
                    </span>
                  )}
                </div>
                <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-ledger-text-dim font-mono tabular-nums">
                  {controversy.polarity && (
                    <span>{controversy.polarity} polarity</span>
                  )}
                  {positions.length > 0 && (
                    <>
                      <span class="text-ledger-border-light">·</span>
                      <span>{positions.length} positions</span>
                    </>
                  )}
                  {linkedThread && (
                    <>
                      <span class="text-ledger-border-light">·</span>
                      <span>Thread: <span class="text-category-policy">{linkedThread.title}</span></span>
                    </>
                  )}
                </div>
              </header>

              <!-- Dual-column position preview -->
              {(previewA || previewB) && (
                <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-ledger-border/60">
                  {previewA && (
                    <div class="p-6">
                      <p class="label-eyebrow mb-2">Position A</p>
                      <p class="font-display italic text-base leading-snug text-ledger-text-muted line-clamp-3" style="font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;">
                        "{previewA.claim}"
                      </p>
                    </div>
                  )}
                  {previewB && (
                    <div class="p-6">
                      <p class="label-eyebrow mb-2">Position B</p>
                      <p class="font-display italic text-base leading-snug text-ledger-text-muted line-clamp-3" style="font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;">
                        "{previewB.claim}"
                      </p>
                    </div>
                  )}
                </div>
              )}

              {rest > 0 && (
                <div class="px-6 py-3 border-t border-ledger-border/60 text-xs font-mono text-ledger-text-dim">
                  + {rest} more {rest === 1 ? 'position' : 'positions'} →
                </div>
              )}
            </a>
          );
        })}
      </div>
    )}
  </section>
</Base>
