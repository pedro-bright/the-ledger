---
import Base from '../../layouts/Base.astro';
import { loadControversies, loadThreads } from '../../lib/content';

const controversies = loadControversies();
const threads = loadThreads();
const threadMap = new Map(threads.map((t) => [t.id, t]));
---

<Base title="Controversies" description="Active debates and contested positions in AI history.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <p class="text-xs font-mono uppercase tracking-[0.2em] text-ledger-text-dim mb-2">
        Active Debates
      </p>
      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-3">Controversies</h1>
      <p class="text-ledger-text-muted max-w-xl">
        Not everything in AI has a clear consensus. These controversies document multiple positions,
        their proponents, and the evidence behind each claim.
      </p>
    </div>

    {controversies.length === 0 ? (
      <div class="text-center py-20">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-ledger-surface border border-ledger-border mb-6">
          <svg class="w-7 h-7 text-ledger-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={1.5}>
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
          </svg>
        </div>
        <h3 class="text-lg font-medium text-ledger-text mb-2">No controversies yet</h3>
        <p class="text-sm text-ledger-text-muted max-w-md mx-auto">
          Controversies are loaded from markdown files in the <code class="font-mono text-xs bg-ledger-surface px-1.5 py-0.5 rounded">content/controversies/</code> directory.
        </p>
      </div>
    ) : (
      <div class="space-y-4">
        {controversies.map((controversy) => {
          const linkedThread = controversy.thread ? threadMap.get(controversy.thread) : null;
          return (
            <a
              href={`/controversies/${controversy.slug}`}
              class="group block p-5 rounded-lg border border-ledger-border bg-ledger-surface/50 hover:bg-ledger-surface hover:border-ledger-border-light transition-all duration-200"
            >
              <div class="flex items-center gap-3 mb-2">
                <h2 class="text-lg font-semibold group-hover:text-white transition-colors">
                  {controversy.title}
                </h2>
                {controversy.status && (
                  <span class={`flex-shrink-0 px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider rounded-full border ${
                    controversy.status === 'active'
                      ? 'text-amber-400 bg-amber-400/10 border-amber-400/20'
                      : controversy.status === 'resolved'
                        ? 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20'
                        : 'text-ledger-text-dim bg-ledger-surface border-ledger-border'
                  }`}>
                    {controversy.status}
                  </span>
                )}
              </div>

              {controversy.positions && controversy.positions.length > 0 && (
                <p class="text-sm text-ledger-text-muted mb-2">
                  {controversy.positions.length} positions documented
                </p>
              )}

              <div class="flex flex-wrap items-center gap-4 text-xs text-ledger-text-dim font-mono">
                {controversy.polarity && (
                  <span>{controversy.polarity} polarity</span>
                )}
                {linkedThread && (
                  <span>
                    Thread: <span class="text-category-policy">{linkedThread.title}</span>
                  </span>
                )}
                {controversy.last_updated && (
                  <span>Updated {new Date(controversy.last_updated).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</span>
                )}
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>
</Base>
