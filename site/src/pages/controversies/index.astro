---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/wiki/PageHeader.astro';
import RailSection from '../../components/wiki/RailSection.astro';
import { loadControversies, loadThreads, getExcerpt } from '../../lib/content';

const controversies = loadControversies();
const threads = loadThreads();
const threadMap = new Map(threads.map((t) => [t.id, t]));

const active = controversies.filter((c) => c.status === 'active');
const other = controversies.filter((c) => c.status !== 'active');

function preview(claim?: string): string {
  if (!claim) return '';
  return claim.length > 120 ? getExcerpt(claim, 120) : claim;
}

function positionCountLabel(n: number): string {
  return `${n} position${n === 1 ? '' : 's'}`;
}
---

<Base
  layout="index"
  title="Controversies"
  description="Claims in active dispute across AI history: positions, proponents, sources."
>
  <PageHeader
    eyebrow="§ Controversies"
    title="Controversies"
    subtitle="Claims in active dispute. Each controversy has multiple positions, each with proponents and sources. ‘Uncontested’ is not a requirement — scholarship evolves."
  />

  {active.length > 0 && (
    <section class="cx-section" id="active">
      <h2
        class="cx-section__head font-display"
        style="font-variation-settings:'opsz' 36, 'SOFT' 0, 'WONK' 0;"
      >Active</h2>
      <div class="cx-grid">
        {active.map((c) => {
          const positions = c.positions || [];
          const linkedThread = c.thread ? threadMap.get(c.thread) : null;
          return (
            <article class="cx-card">
              <h3 class="cx-card__title font-display" style="font-variation-settings:'opsz' 36, 'SOFT' 0, 'WONK' 0;">
                <a href={`/controversies/${c.slug}`}>{c.title}</a>
              </h3>
              <p class="cx-card__meta font-mono">
                {linkedThread && (
                  <>
                    <a href={`/threads/${linkedThread.slug}`}>{linkedThread.title}</a>
                    <span class="cx-sep" aria-hidden="true">·</span>
                  </>
                )}
                {c.polarity && (
                  <>
                    <span>{c.polarity}</span>
                    <span class="cx-sep" aria-hidden="true">·</span>
                  </>
                )}
                <span>{positionCountLabel(positions.length)}</span>
              </p>
              {(positions[0] || positions[1]) && (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 cx-card__positions">
                  {positions[0] && (
                    <div class="cx-pos">
                      <p class="label-eyebrow cx-pos__label">Position A</p>
                      <p class="cx-pos__claim">“{preview(positions[0].claim)}”</p>
                    </div>
                  )}
                  {positions[1] && (
                    <div class="cx-pos">
                      <p class="label-eyebrow cx-pos__label">Position B</p>
                      <p class="cx-pos__claim">“{preview(positions[1].claim)}”</p>
                    </div>
                  )}
                </div>
              )}
              <p class="cx-card__link">
                <a href={`/controversies/${c.slug}`}>Full debate →</a>
              </p>
            </article>
          );
        })}
      </div>
    </section>
  )}

  {other.length > 0 && (
    <section class="cx-section" id="resolved">
      <h2
        class="cx-section__head font-display"
        style="font-variation-settings:'opsz' 36, 'SOFT' 0, 'WONK' 0;"
      >Resolved or dormant</h2>
      <div class="cx-grid">
        {other.map((c) => {
          const positions = c.positions || [];
          const linkedThread = c.thread ? threadMap.get(c.thread) : null;
          return (
            <article class="cx-card cx-card--muted">
              <h3 class="cx-card__title font-display" style="font-variation-settings:'opsz' 36, 'SOFT' 0, 'WONK' 0;">
                <a href={`/controversies/${c.slug}`}>{c.title}</a>
              </h3>
              <p class="cx-card__meta font-mono">
                {linkedThread && (
                  <>
                    <a href={`/threads/${linkedThread.slug}`}>{linkedThread.title}</a>
                    <span class="cx-sep" aria-hidden="true">·</span>
                  </>
                )}
                {c.status && (
                  <>
                    <span>{c.status}</span>
                    <span class="cx-sep" aria-hidden="true">·</span>
                  </>
                )}
                {c.polarity && (
                  <>
                    <span>{c.polarity}</span>
                    <span class="cx-sep" aria-hidden="true">·</span>
                  </>
                )}
                <span>{positionCountLabel(positions.length)}</span>
              </p>
              {(positions[0] || positions[1]) && (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 cx-card__positions">
                  {positions[0] && (
                    <div class="cx-pos">
                      <p class="label-eyebrow cx-pos__label">Position A</p>
                      <p class="cx-pos__claim">“{preview(positions[0].claim)}”</p>
                    </div>
                  )}
                  {positions[1] && (
                    <div class="cx-pos">
                      <p class="label-eyebrow cx-pos__label">Position B</p>
                      <p class="cx-pos__claim">“{preview(positions[1].claim)}”</p>
                    </div>
                  )}
                </div>
              )}
              <p class="cx-card__link">
                <a href={`/controversies/${c.slug}`}>Full debate →</a>
              </p>
            </article>
          );
        })}
      </div>
    </section>
  )}

  {controversies.length === 0 && (
    <p class="cx-empty">Controversies are loaded from <code>content/controversies/</code>.</p>
  )}

  <Fragment slot="leftRail">
    <RailSection title="Navigate">
      <ul class="rail-list rail-list--plain">
        <li><a href="/">Main page</a></li>
        <li><a href="/explore">Timeline</a></li>
        <li><a href="/threads">Threads</a></li>
        <li><a href="/controversies">Controversies</a></li>
        <li><a href="/actors">Actors</a></li>
        <li><a href="/graph">Graph</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </RailSection>

    <RailSection title="On this page">
      <ul class="rail-list rail-list--plain">
        {active.length > 0 && <li><a href="#active">Active ({active.length})</a></li>}
        {other.length > 0 && <li><a href="#resolved">Resolved or dormant ({other.length})</a></li>}
      </ul>
    </RailSection>
  </Fragment>
</Base>

<style>
  .cx-section {
    margin: 0 0 36px;
    scroll-margin-top: 20px;
  }
  .cx-section__head {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-ink-dim);
    margin: 0 0 14px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--color-rule);
  }
  .cx-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .cx-card {
    border: 1px solid var(--color-rule);
    background: color-mix(in srgb, var(--color-wiki-surface) 30%, transparent);
    padding: 14px 16px;
    border-radius: 2px;
  }
  .cx-card--muted {
    background: color-mix(in srgb, var(--color-wiki-surface) 15%, transparent);
  }
  .cx-card__title {
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.003em;
    margin: 0 0 4px;
    color: var(--color-ink-dim);
  }
  .cx-card__title a {
    color: var(--color-wiki-link);
  }
  .cx-card__title a:hover { text-decoration: underline; }
  .cx-card__meta {
    font-size: 12px;
    color: var(--color-ink-faint);
    margin: 0 0 10px;
    letter-spacing: 0.02em;
  }
  .cx-card__meta a { color: var(--color-wiki-link); }
  .cx-card__meta a:hover { text-decoration: underline; }
  .cx-sep { color: var(--color-rule-strong); margin: 0 6px; }
  .cx-card__positions { margin-top: 6px; }
  .cx-pos {
    border-left: 2px solid var(--color-rule-strong);
    padding: 2px 0 2px 10px;
  }
  .cx-pos__label { margin: 0 0 4px; }
  .cx-pos__claim {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;
    font-style: italic;
    font-size: 0.9375rem;
    line-height: 1.45;
    color: var(--color-ink-mid);
    margin: 0;
  }
  .cx-card__link {
    margin: 10px 0 0;
    font-family: var(--font-sans);
    font-size: 13px;
  }
  .cx-card__link a { color: var(--color-wiki-link); }
  .cx-card__link a:hover { text-decoration: underline; }
  .cx-empty {
    font-family: var(--font-serif);
    color: var(--color-ink-mid);
  }
  .cx-empty code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-wiki-surface);
    padding: 0.1em 0.35em;
    border-radius: 2px;
  }
</style>
