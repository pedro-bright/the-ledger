---
import Base from '../../layouts/Base.astro';
import ArticleShell from '../../components/wiki/ArticleShell.astro';
import Infobox from '../../components/wiki/Infobox.astro';
import EventRow from '../../components/wiki/EventRow.astro';
import RailSection from '../../components/wiki/RailSection.astro';
import { loadActors, loadEvents, buildActorEventMap } from '../../lib/content';

export function getStaticPaths() {
  const actors = loadActors();
  return actors.map((actor) => ({
    params: { id: actor.id },
    props: { actor },
  }));
}

const { actor } = Astro.props;
const events = loadEvents();
const allActors = loadActors();
const actorEventMap = buildActorEventMap(events);
const actorEvents = actorEventMap.get(actor.id) || [];

// Group events by year desc; within each year, sort by date desc
const byYear = new Map<number, typeof actorEvents>();
for (const e of actorEvents) {
  const y = new Date(e.date).getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(e);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
for (const y of years) {
  byYear.get(y)!.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
}

// Top categories tally
const catCounts = new Map<string, number>();
for (const e of actorEvents) {
  catCounts.set(e.category, (catCounts.get(e.category) || 0) + 1);
}
const topCategories = [...catCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);

const typeDisplay: Record<string, string> = {
  company: 'company',
  'research-lab': 'research laboratory',
  government: 'government body',
  individual: 'individual',
  organization: 'organization',
};
const typeLabel: Record<string, string> = {
  company: 'Company',
  'research-lab': 'Research lab',
  government: 'Government',
  individual: 'Individual',
  organization: 'Organization',
};

const entryCount = actorEvents.length;
const subtitle = `A ${typeDisplay[actor.type] || 'entity'} referenced in ${entryCount} ledger ${entryCount === 1 ? 'entry' : 'entries'}.`;

// Related: same type, excluding self, alphabetical, up to 6
const related = allActors
  .filter((a) => a.type === actor.type && a.id !== actor.id)
  .sort((a, b) => a.name.localeCompare(b.name))
  .slice(0, 6);

// Short list of same-type actors for left rail (up to 10, alphabetical)
const sameTypeRail = allActors
  .filter((a) => a.type === actor.type && a.id !== actor.id)
  .sort((a, b) => a.name.localeCompare(b.name))
  .slice(0, 10);

function cleanUrl(url: string): string {
  return url.replace(/^https?:\/\//, '').replace(/\/$/, '');
}
---

<Base
  layout="article"
  title={actor.name}
  description={`Ledger entries involving ${actor.name}.`}
>
  <ArticleShell
    title={actor.name}
    subtitle={subtitle}
    breadcrumb={[
      { label: 'Main page', href: '/' },
      { label: 'Actors', href: '/actors' },
      { label: actor.name },
    ]}
    sourcePath={`content/actors/${actor.id}.yml`}
  >
    <Fragment slot="infobox">
      <Infobox title="Actor metadata">
        <dl>
          <dt>Type</dt>
          <dd>{typeLabel[actor.type] || actor.type}</dd>
          {actor.founded && (
            <>
              <dt>Founded</dt>
              <dd><span class="mono">{actor.founded}</span></dd>
            </>
          )}
          {actor.website && (
            <>
              <dt>Website</dt>
              <dd>
                <a href={actor.website} target="_blank" rel="noopener noreferrer">
                  {cleanUrl(actor.website)}
                </a>
              </dd>
            </>
          )}
          {actor.aliases && actor.aliases.length > 0 && (
            <>
              <dt>Aliases</dt>
              <dd><span class="mono">{actor.aliases.join(', ')}</span></dd>
            </>
          )}
          <dt>Entries</dt>
          <dd><span class="mono">{entryCount}</span></dd>
          <dt>ID</dt>
          <dd><span class="mono">{actor.id}</span></dd>
        </dl>
      </Infobox>
    </Fragment>

    {entryCount === 0 ? (
      <p><em>No tracked ledger entries yet.</em></p>
    ) : (
      <Fragment>
        <p>
          {actor.name} appears across <strong>{entryCount}</strong> {entryCount === 1 ? 'entry' : 'entries'}
          {years.length > 0 && (
            <> spanning <span class="font-mono">{years[years.length - 1]}</span>–<span class="font-mono">{years[0]}</span></>
          )}.
        </p>
        {years.map((year) => (
          <section class="actor-year" id={`y-${year}`}>
            <h2>{year}</h2>
            <ul class="actor-year__list">
              {byYear.get(year)!.map((e) => (
                <EventRow event={e} />
              ))}
            </ul>
          </section>
        ))}
      </Fragment>
    )}

    {related.length > 0 && (
      <Fragment slot="seeAlso">
        <ul>
          {related.map((a) => (
            <li><a href={`/actors/${a.id}`}>{a.name}</a></li>
          ))}
          <li><a href="/actors">All actors</a></li>
        </ul>
      </Fragment>
    )}
  </ArticleShell>

  <Fragment slot="leftRail">
    <RailSection title="Navigate">
      <ul class="rail-list rail-list--plain">
        <li><a href="/">Main page</a></li>
        <li><a href="/actors">All actors</a></li>
        <li><a href="/explore">Timeline</a></li>
        <li><a href="/threads">Threads</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </RailSection>

    {years.length > 1 && (
      <RailSection title="Years">
        <ul class="rail-list">
          {years.map((y) => (
            <li>
              <a href={`#y-${y}`}>{y}</a>
              <span class="count">{byYear.get(y)!.length}</span>
            </li>
          ))}
        </ul>
      </RailSection>
    )}

    {sameTypeRail.length > 0 && (
      <RailSection title={`Other ${(typeLabel[actor.type] || 'actors').toLowerCase()}s`}>
        <ul class="rail-list rail-list--plain">
          {sameTypeRail.map((a) => (
            <li><a href={`/actors/${a.id}`}>{a.name}</a></li>
          ))}
        </ul>
      </RailSection>
    )}
  </Fragment>

  {topCategories.length > 0 && (
    <Fragment slot="rightRail">
      <RailSection title="Categories appeared in">
        <ul class="rail-list">
          {topCategories.map(([cat, n]) => (
            <li>
              <a href={`/explore?category=${cat}`}>{cat.replace('-', ' ')}</a>
              <span class="count">{n}</span>
            </li>
          ))}
        </ul>
      </RailSection>
    </Fragment>
  )}
</Base>

<style>
  .actor-year {
    margin: 1.5rem 0 0;
    scroll-margin-top: 20px;
  }
  .actor-year h2 {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 36, 'SOFT' 0, 'WONK' 0;
    font-weight: 500;
    font-size: 1.25rem;
    color: var(--color-ink-dim);
    margin: 1.25rem 0 0.4rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .actor-year__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
