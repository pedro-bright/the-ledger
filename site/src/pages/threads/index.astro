---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/wiki/PageHeader.astro';
import RailSection from '../../components/wiki/RailSection.astro';
import { loadThreads, loadEvents, buildThreadEventMap } from '../../lib/content';

const threads = loadThreads();
const events = loadEvents();
const threadEventMap = buildThreadEventMap(events);

type EnrichedThread = ReturnType<typeof enrich>;
function enrich(t: (typeof threads)[number]) {
  const evts = threadEventMap.get(t.id) || [];
  const eventCount = t.events?.length || evts.length;
  // Last updated = max of explicit `last_updated` or latest event date in thread.
  let latestTs = t.last_updated ? new Date(t.last_updated).getTime() : 0;
  for (const e of evts) {
    const et = new Date(e.date).getTime();
    if (!Number.isNaN(et) && et > latestTs) latestTs = et;
  }
  const lastUpdated = latestTs > 0 ? new Date(latestTs).toISOString().slice(0, 10) : undefined;
  return { ...t, eventCount, lastUpdated };
}

const allEnriched: EnrichedThread[] = threads.map(enrich);
// Active first, then by event count desc.
allEnriched.sort((a, b) => b.eventCount - a.eventCount);

const active = allEnriched.filter((t) => t.status === 'active');
const dormant = allEnriched.filter((t) => t.status !== 'active');
---

<Base
  title="Threads"
  description="Narrative threads in The Ledger — long-running lines of inquiry that connect events into a larger story."
  layout="index"
>
  <Fragment slot="leftRail">
    <RailSection title="Navigate">
      <ul class="rail-list">
        <li><a href="/">Main page</a></li>
        <li><a href="/explore">Timeline</a></li>
        <li><a href="/controversies">Controversies</a></li>
        <li><a href="/actors">Actors</a></li>
        <li><a href="/about">About the ledger</a></li>
      </ul>
    </RailSection>

    <RailSection title="Threads by status">
      <ul class="rail-list">
        <li><span>Active</span><span class="count">{active.length}</span></li>
        <li><span>Dormant</span><span class="count">{dormant.length}</span></li>
        <li><span>Total</span><span class="count">{allEnriched.length}</span></li>
      </ul>
    </RailSection>

    <RailSection title="About threads">
      <p>
        Threads are long-running lines of inquiry. Each bundles a group of events around a single question and carries a named curator responsible for its synthesis.
      </p>
      <p>
        A thread never resolves — understanding always evolves. Status tracks whether the curator is still actively maintaining it.
      </p>
    </RailSection>
  </Fragment>

  <PageHeader
    eyebrow="§ Threads"
    title="Narrative threads"
    subtitle="Long-running lines of inquiry. Each thread links events into a larger story; each has a named curator responsible for its synthesis."
  />

  {allEnriched.length === 0 ? (
    <p class="threads-empty">
      No threads are loaded yet. Threads are written in <code>content/threads/</code>.
    </p>
  ) : (
    <>
      {active.length > 0 && (
        <section class="threads-section">
          <h2 class="threads-section__head">
            Active
            <span class="threads-section__count font-mono">{active.length}</span>
          </h2>
          <table class="threads-table">
            <thead>
              <tr>
                <th scope="col">Thread</th>
                <th scope="col" class="threads-table__col-curator">Curator</th>
                <th scope="col" class="threads-table__col-count">Events</th>
                <th scope="col" class="threads-table__col-date">Updated</th>
              </tr>
            </thead>
            <tbody>
              {active.map((t) => (
                <tr>
                  <td class="threads-table__title-cell">
                    <a href={`/threads/${t.slug}`} class="threads-table__title">{t.title}</a>
                    {t.core_question && (
                      <p class="threads-table__question">{t.core_question}</p>
                    )}
                  </td>
                  <td class="threads-table__curator font-mono">{t.curator || '—'}</td>
                  <td class="threads-table__count font-mono">{t.eventCount}</td>
                  <td class="threads-table__date font-mono">
                    {t.lastUpdated ? <time datetime={t.lastUpdated}>{t.lastUpdated}</time> : '—'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )}

      {dormant.length > 0 && (
        <section class="threads-section">
          <h2 class="threads-section__head">
            Dormant
            <span class="threads-section__count font-mono">{dormant.length}</span>
          </h2>
          <table class="threads-table threads-table--dormant">
            <thead>
              <tr>
                <th scope="col">Thread</th>
                <th scope="col" class="threads-table__col-curator">Curator</th>
                <th scope="col" class="threads-table__col-count">Events</th>
                <th scope="col" class="threads-table__col-date">Updated</th>
              </tr>
            </thead>
            <tbody>
              {dormant.map((t) => (
                <tr>
                  <td class="threads-table__title-cell">
                    <a href={`/threads/${t.slug}`} class="threads-table__title">{t.title}</a>
                    {t.core_question && (
                      <p class="threads-table__question">{t.core_question}</p>
                    )}
                  </td>
                  <td class="threads-table__curator font-mono">{t.curator || '—'}</td>
                  <td class="threads-table__count font-mono">{t.eventCount}</td>
                  <td class="threads-table__date font-mono">
                    {t.lastUpdated ? <time datetime={t.lastUpdated}>{t.lastUpdated}</time> : '—'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )}
    </>
  )}
</Base>

<style>
  .threads-empty {
    color: var(--color-ink-mid);
    font-style: italic;
    padding: 24px 0;
  }
  .threads-empty code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-wiki-surface);
    padding: 0.1em 0.35em;
    border-radius: 2px;
  }

  .threads-section {
    margin-bottom: 48px;
  }
  .threads-section:last-child { margin-bottom: 0; }
  .threads-section__head {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 36, 'SOFT' 0, 'WONK' 0;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-ink-dim);
    margin: 0 0 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--color-rule);
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .threads-section__count {
    font-size: 13px;
    font-weight: 400;
    color: var(--color-ink-faint);
    letter-spacing: 0.04em;
  }

  .threads-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-serif);
  }
  .threads-table thead th {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-ink-muted);
    text-align: left;
    padding: 6px 10px;
    border-bottom: 1px solid var(--color-rule-strong);
  }
  .threads-table__col-curator {
    width: 12em;
    white-space: nowrap;
  }
  .threads-table__col-count {
    width: 5em;
    text-align: right;
  }
  .threads-table__col-date {
    width: 8em;
    white-space: nowrap;
    text-align: right;
  }
  .threads-table tbody tr {
    border-bottom: 1px solid var(--color-rule);
    transition: background 120ms ease;
  }
  .threads-table tbody tr:hover {
    background: rgba(240, 237, 228, 0.45);
  }
  .threads-table td {
    padding: 12px 10px;
    vertical-align: top;
  }
  .threads-table__title-cell {
    padding-right: 24px;
  }
  .threads-table__title {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-wiki-link);
    line-height: 1.3;
  }
  .threads-table__title:visited { color: var(--color-wiki-link-visited); }
  .threads-table__title:hover { text-decoration: underline; }
  .threads-table__question {
    margin: 4px 0 0;
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;
    font-style: italic;
    font-size: 0.9375rem;
    line-height: 1.45;
    color: var(--color-ink-mid);
    max-width: 60ch;
  }
  .threads-table__curator {
    font-size: 12.5px;
    color: var(--color-ink-mid);
  }
  .threads-table__count {
    font-size: 13px;
    color: var(--color-ink-mid);
    text-align: right;
  }
  .threads-table__date {
    font-size: 12.5px;
    color: var(--color-ink-faint);
    text-align: right;
  }
  .threads-table--dormant .threads-table__title {
    color: var(--color-ink-mid);
  }

  @media (max-width: 680px) {
    .threads-table thead { display: none; }
    .threads-table tr {
      display: block;
      padding: 10px 0;
    }
    .threads-table td {
      display: block;
      padding: 2px 0;
    }
    .threads-table__title-cell { padding-right: 0; }
    .threads-table__curator::before {
      content: 'Curator: ';
      color: var(--color-ink-faint);
    }
    .threads-table__count::before {
      content: 'Events: ';
      color: var(--color-ink-faint);
    }
    .threads-table__date::before {
      content: 'Updated: ';
      color: var(--color-ink-faint);
    }
    .threads-table__count,
    .threads-table__date { text-align: left; }
  }
</style>
