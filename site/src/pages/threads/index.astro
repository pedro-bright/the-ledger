---
import Base from '../../layouts/Base.astro';
import { loadThreads, loadEvents, buildThreadEventMap } from '../../lib/content';

const threads = loadThreads();
const events = loadEvents();
const threadEventMap = buildThreadEventMap(events);

const enriched = threads
  .map((t) => ({
    ...t,
    eventCount: t.events?.length || (threadEventMap.get(t.id)?.length ?? 0),
  }))
  .sort((a, b) => {
    // Active first, then by event count desc.
    if (a.status !== b.status) {
      if (a.status === 'active') return -1;
      if (b.status === 'active') return 1;
    }
    return b.eventCount - a.eventCount;
  });
---

<Base title="Threads" description="Narrative arcs connecting events in AI history.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-14">
      <p class="label-eyebrow mb-3">§ Narrative Arcs</p>
      <h1 class="font-display text-display-sm font-normal text-white mb-4 leading-[1.05]" style="font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;">Threads</h1>
      <p class="font-display italic text-lg text-ledger-text-muted max-w-[58ch] leading-relaxed" style="font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;">
        Threads connect events into narrative arcs — tracing how themes and debates evolve across time. Each has a signed canonical synthesis.
      </p>
    </div>

    {enriched.length === 0 ? (
      <div class="py-20 px-4 max-w-xl mx-auto text-center">
        <p class="label-eyebrow mb-3">§ No threads yet</p>
        <p class="font-display text-3xl font-normal text-ledger-text leading-tight" style="font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;">
          Narrative arcs take time to assemble.
        </p>
        <p class="text-sm text-ledger-text-muted mt-4 leading-relaxed">
          Threads are loaded from <code class="font-mono text-xs text-ledger-text">content/threads/</code>.
        </p>
      </div>
    ) : (
      <ol class="divide-y divide-ledger-border">
        {enriched.map((thread, idx) => (
          <li>
            <a
              href={`/threads/${thread.slug}`}
              class="group block py-8 hover:bg-ledger-surface/20 -mx-4 px-4 rounded-sm transition-colors"
            >
              <div class="grid md:grid-cols-[auto_1fr_auto] gap-4 md:gap-6 items-start">
                <span class="font-mono text-xs text-ledger-text-dim tabular-nums md:w-10">
                  № {String(idx + 1).padStart(2, '0')}
                </span>
                <div>
                  <div class="flex items-center flex-wrap gap-2 mb-2">
                    <h2 class="font-display text-2xl sm:text-3xl font-medium leading-tight text-ledger-text group-hover:text-white transition-colors" style="font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;">
                      {thread.title}
                    </h2>
                    {thread.status && (
                      <span class={`flex-shrink-0 px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider rounded-sm border ${
                        thread.status === 'active'
                          ? 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20'
                          : 'text-ledger-text-dim bg-ledger-surface border-ledger-border'
                      }`}>
                        {thread.status}
                      </span>
                    )}
                  </div>
                  {thread.core_question && (
                    <p class="font-display italic text-base sm:text-lg text-ledger-text-muted mb-3 leading-snug max-w-[62ch]" style="font-variation-settings: 'opsz' 14, 'SOFT' 0, 'WONK' 0;">
                      "{thread.core_question}"
                    </p>
                  )}
                  <div class="flex items-center gap-3 text-xs text-ledger-text-dim font-mono tabular-nums">
                    {thread.started && (
                      <span>Since {new Date(thread.started).getFullYear()}</span>
                    )}
                    {thread.events && (
                      <>
                        <span class="text-ledger-border-light">·</span>
                        <span>{thread.events.length} events</span>
                      </>
                    )}
                    {thread.curator && (
                      <>
                        <span class="text-ledger-border-light">·</span>
                        <span>{thread.curator}</span>
                      </>
                    )}
                  </div>
                </div>
                <span class="hidden md:inline-flex items-start font-mono text-xs text-ledger-text-dim group-hover:text-category-policy transition-colors pt-1.5 whitespace-nowrap">
                  read →
                </span>
              </div>
            </a>
          </li>
        ))}
      </ol>
    )}
  </section>
</Base>
